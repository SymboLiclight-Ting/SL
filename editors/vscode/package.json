{
  "name": "symboliclight-vscode",
  "displayName": "SymbolicLight SL",
  "description": "Developer preview support for SL files.",
  "version": "0.5.0",
  "publisher": "symboliclight",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:symboliclight"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "symboliclight",
        "aliases": ["SL", "SymbolicLight"],
        "extensions": [".sl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "symboliclight",
        "scopeName": "source.sl",
        "path": "./syntaxes/symboliclight.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "symboliclight",
        "path": "./snippets/symboliclight.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
